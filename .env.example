# =============================================================================
# Twype Voice — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://twype:REPLACE_ME@postgres:5432/twype

# --- API (FastAPI) ---
JWT_SECRET=
RESEND_API_KEY=

# --- LiveKit ---
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=
LIVEKIT_URL=ws://livekit:7880

# --- Agent ---
GOOGLE_API_KEY=
LITELLM_URL=http://litellm:4000
LLM_MODEL=gemini-flash-lite
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512
DEEPGRAM_API_KEY=
STT_LANGUAGE=multi
STT_MODEL=nova-3
RAG_ENABLED=true
RAG_TOP_K=5
RAG_LANGUAGE_BOOST=1.5
RAG_EMBEDDING_TIMEOUT=3.0

# --- Agent Voice Pipeline ---
# Turn detection mode: stt | vad | manual
TURN_DETECTION_MODE=stt

# Endpointing delays (seconds)
MIN_ENDPOINTING_DELAY=0.5
MAX_ENDPOINTING_DELAY=3.0

# Start LLM generation before end-of-turn is confirmed
PREEMPTIVE_GENERATION=true

# Apply noise cancellation before VAD/STT
NOISE_CANCELLATION_ENABLED=true

# False interruption handling (seconds)
# Set to 0 to disable false interruption detection
FALSE_INTERRUPTION_TIMEOUT=2.0

# Speech shorter than this threshold won't interrupt agent speech (seconds)
MIN_INTERRUPTION_DURATION=0.5

# Thinking sounds / filler phrases while waiting for first LLM token
THINKING_SOUNDS_ENABLED=true
THINKING_SOUNDS_DELAY=1.5

# --- Agent TTS ---
# Provider: inworld | elevenlabs
TTS_PROVIDER=inworld

# Inworld (primary)
INWORLD_API_KEY=
TTS_INWORLD_VOICE=Olivia
TTS_INWORLD_MODEL=inworld-tts-1.5-mini
TTS_SPEAKING_RATE=1.0
TTS_TEMPERATURE=1.0

# ElevenLabs (fallback)
ELEVENLABS_API_KEY=
TTS_ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
TTS_ELEVENLABS_MODEL=eleven_flash_v2_5

# --- LiteLLM Proxy ---
# Reuses GOOGLE_API_KEY from the Agent section above for Gemini-backed models.
LITELLM_MASTER_KEY=
OPENAI_API_KEY=

# --- coturn ---
TURN_USERNAME=twype
TURN_PASSWORD=
EXTERNAL_IP=127.0.0.1

# --- PostgreSQL container ---
POSTGRES_USER=twype
POSTGRES_PASSWORD=
POSTGRES_DB=twype
