# =============================================================================
# Twype Voice — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://twype:REPLACE_ME@postgres:5432/twype

# --- API (FastAPI) ---
JWT_SECRET=
RESEND_API_KEY=

# --- LiveKit ---
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=
LIVEKIT_URL=ws://livekit:7880

# --- Agent ---
LITELLM_URL=http://litellm:4000
DEEPGRAM_API_KEY=
STT_LANGUAGE=multi
STT_MODEL=nova-3
INWORLD_API_KEY=
ELEVENLABS_API_KEY=

# --- LiteLLM Proxy ---
LITELLM_MASTER_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# --- coturn ---
TURN_USERNAME=twype
TURN_PASSWORD=
EXTERNAL_IP=127.0.0.1

# --- PostgreSQL container ---
POSTGRES_USER=twype
POSTGRES_PASSWORD=
POSTGRES_DB=twype
